# ═══════════════════════════════════════════════════════════════════
# Part 3 — Environment template
# Copy to .env and fill in OPENROUTER_API_KEY
# ═══════════════════════════════════════════════════════════════════

# ── API key (always required) ──────────────────────────────────────
OPENROUTER_API_KEY=

# ── Model ──────────────────────────────────────────────────────────
# Haiku 4.5 = best balance for this group chat use case.
# Cleaner code (no duplicate-line bug), better tool use, ~$0.33/session.
# Requires MAX_ROUNDS>=10 (Claude needs more tool rounds than gpt-4o-mini).
MODEL=anthropic/claude-haiku-4.5

# Cheaper alternative (~$0.04/session) — but has edit_file duplication issues
# MODEL=openai/gpt-4o-mini

# Premium alternative (~$1/session) — bästa kvalitet, used for max performance
# MODEL=anthropic/claude-sonnet-4.5


# ═══════════════════════════════════════════════════════════════════
# CHOOSE MODE — uncomment ONE block below (LOCAL TEST or LIVE HUB)
# ═══════════════════════════════════════════════════════════════════

# ── LOCAL TEST (mock hub via docker compose) ───────────────────────
AGENT_NAME=macmini1
HUB_URL=http://localhost:8080
HUB_PASSWORD=th25-agents-vg
DRY_RUN=false
RESPONSE_DELAY=1

# ── LIVE HUB (examination 2026-05-29) ──────────────────────────────
# AGENT_NAME=marcus-macmini1
# HUB_URL=https://wb48jtfnjng6on-8080.proxy.runpod.net
# HUB_PASSWORD=th25-agents-vg
# DRY_RUN=false
# RESPONSE_DELAY=2


# ═══════════════════════════════════════════════════════════════════
# Caps (apply to both modes)
# ═══════════════════════════════════════════════════════════════════

# Message cap — hub also enforces 10/agent server-side
MSG_CAP=10

# Token budget — soft limit at 75%, hard limit at 90% (sign-off)
# 150k allows roughly 8-10 full message cycles before hard limit
TOKEN_CAP=150000

# Poll interval in seconds
POLL_INTERVAL=4


# ═══════════════════════════════════════════════════════════════════
# Tool settings (rarely changed)
# ═══════════════════════════════════════════════════════════════════

WORKSPACE_DIR=./workspace
MAX_OUTPUT=5000
# Max LLM tool-calling rounds per decide().
# Claude (Haiku/Sonnet) needs >=10 to complete; gpt-4o-mini works with 6.
MAX_ROUNDS=10
AUTO_APPROVE=true
DEBUG=false
