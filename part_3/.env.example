# ═══════════════════════════════════════════════════════════════════
# Part 3 — Environment template
# Copy to .env and fill in OPENROUTER_API_KEY
# ═══════════════════════════════════════════════════════════════════

# ── API key (always required) ──────────────────────────────────────
OPENROUTER_API_KEY=

# ── Model ──────────────────────────────────────────────────────────
# Gemini 2.5 Flash = winner of the model shootout (2026-05).
# Most focused on the actual task (no extra distractor files), 100% prose
# reports (no auto-summary fallback noise), ~$0.15/session.
MODEL=google/gemini-2.5-flash

# Verified alternatives — drop in by uncommenting:
# MODEL=openai/gpt-4.1-mini       # ~$0.11/session — same quality, slightly distracted by suggestions
# MODEL=deepseek/deepseek-chat    # ~$0.10/session — cheapest, most distracted by suggestions
# MODEL=openai/gpt-4o-mini        # ~$0.04/session — fallback; has edit_file dup bug
# MODEL=anthropic/claude-haiku-4.5  # ~$0.33/session — worked but ignored specific filenames in noise
# MODEL=anthropic/claude-sonnet-4.5  # ~$1/session — premium quality, over budget for testing


# ═══════════════════════════════════════════════════════════════════
# CHOOSE MODE — uncomment ONE block below (LOCAL TEST or LIVE HUB)
# ═══════════════════════════════════════════════════════════════════

# ── LOCAL TEST (mock hub via docker compose) ───────────────────────
AGENT_NAME=macmini1
HUB_URL=http://localhost:8080
HUB_PASSWORD=th25-agents-vg
DRY_RUN=false
RESPONSE_DELAY=1

# ── LIVE HUB (examination 2026-05-29) ──────────────────────────────
# AGENT_NAME=marcus-macmini1
# HUB_URL=https://wb48jtfnjng6on-8080.proxy.runpod.net
# HUB_PASSWORD=th25-agents-vg
# DRY_RUN=false
# RESPONSE_DELAY=2


# ═══════════════════════════════════════════════════════════════════
# Caps (apply to both modes)
# ═══════════════════════════════════════════════════════════════════

# Message cap — hub also enforces 10/agent server-side
MSG_CAP=10

# Token budget — soft limit at 75%, hard limit at 90% (sign-off)
# 150k allows roughly 8-10 full message cycles before hard limit
TOKEN_CAP=150000

# Poll interval in seconds
POLL_INTERVAL=4


# ═══════════════════════════════════════════════════════════════════
# Tool settings (rarely changed)
# ═══════════════════════════════════════════════════════════════════

WORKSPACE_DIR=./workspace
MAX_OUTPUT=5000
# Max LLM tool-calling rounds per decide().
# Claude (Haiku/Sonnet) needs >=10 to complete; gpt-4o-mini works with 6.
MAX_ROUNDS=10
# Per LLM call output cap (Haiku needs >=2048 to avoid truncated tool calls)
MAX_TOKENS=2048
AUTO_APPROVE=true
DEBUG=false
# TRACE=1 — write [trace] lines to logs (PASS reasons, LLM previews, tool I/O)
# TRACE=1
# QUIET_STDOUT=1 — logs only in logs/<agent>.log (use: tail -f logs/*.log)
