# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# ── Cloud model choices (OpenRouter) ──────────────────────────────────
# CLOUD_MODEL   = the model that does hard-reasoning workers + integration.
# ROUTER_MODEL  = the model that decomposes a task into parallel workers
#                 (short JSON job — a cheap model is fine here).
# COMPACTION_MODEL = summarises old conversation turns ("local" = free).
CLOUD_MODEL=anthropic/claude-sonnet-4-6
ROUTER_MODEL=openai/gpt-5-mini
COMPACTION_MODEL=local

# ── Local model choices (LM Studio) ───────────────────────────────────
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL=gemma-4-26b-a4b-it-mlx

# Dual-local switch: set LOCAL_MODEL_2 to a second model ID that LM Studio
# is serving, and two local workers will run truly in parallel (two separate
# model instances). Leave empty for single-local mode (default).
LOCAL_MODEL_2=
# LOCAL_MODEL_2=qwen2.5-coder-7b-instruct-mlx

# Optional: LM Studio API key (default is "lm-studio")
# LOCAL_API_KEY=lm-studio
