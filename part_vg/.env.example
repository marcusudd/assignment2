# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# ── Cloud model choices (OpenRouter) ──────────────────────────────────
# CLOUD_MODEL   = tests + integration pass (demo: Haiku).
# ROUTER_MODEL  = decomposes tasks into parallel workers (cheap model OK).
# COMPACTION_MODEL = summarises old turns ("local" = LM Studio LOCAL_MODEL).
CLOUD_MODEL=anthropic/claude-haiku-4-5
ROUTER_MODEL=openai/gpt-5-mini
COMPACTION_MODEL=local

# ── Local model (LM Studio) — recommended: single-local ─────────────
# Load ONE model in LM Studio before demo. Mode 3 still runs parallel
# workers; they share the same model ID (VG.1 = parallel agents, not
# parallel model loads).
#
# M4 Max / 36GB: gemma-4-26b-a4b-it-mlx is the default capable choice.
# If 26b fails resource guard, unload other models or fall back to e4b.
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL=gemma-4-26b-a4b-it-mlx

# Dual-local (optional): only if RAM can keep two models loaded without swap.
# Leave unset for stable demo — avoids LM Studio load/swap during fan-out.
# LOCAL_MODEL_2=gemma-4-e4b-it-mlx

# Optional: LM Studio API key (default is "lm-studio")
# LOCAL_API_KEY=lm-studio
