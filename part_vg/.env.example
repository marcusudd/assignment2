# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# ── Cloud model choices (OpenRouter) ──────────────────────────────────
# CLOUD_MODEL   = hard-reasoning workers + integration pass.
# ROUTER_MODEL  = decomposes tasks into parallel workers (cheap model OK).
# COMPACTION_MODEL = summarises old turns ("local" = free LM Studio model).
CLOUD_MODEL=anthropic/claude-sonnet-4-6
ROUTER_MODEL=openai/gpt-5-mini
COMPACTION_MODEL=local

# ── Local model choices (LM Studio) ───────────────────────────────────
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL=gemma-4-26b-a4b-it-mlx

# Dual-local: second model for true parallel local workers (VG.1 bonus).
# Recommended for demo: gemma-4-e4b (~3 GB, same tool-calling family as Gemma).
# Verify before demo:  python scripts/test_local_toolcall.py
LOCAL_MODEL_2=gemma-4-e4b
# LOCAL_MODEL_2=

# Optional: LM Studio API key (default is "lm-studio")
# LOCAL_API_KEY=lm-studio
